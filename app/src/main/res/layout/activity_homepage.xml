<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#BFFFFFFF"
    tools:context=".homepage"
    tools:ignore="SpUsage,HardcodedText">

    <TextView
        android:id="@+id/homegradient"
        android:layout_width="412dp"
        android:layout_height="312dp"
        android:background="@drawable/home_gradient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/Homepage"
        android:layout_width="wrap_content"
        android:layout_height="72dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="44dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:shadowColor="#99000000"
        android:shadowDx="3"
        android:shadowDy="3"
        android:shadowRadius="3"
        android:text="ShopSeeker"
        android:textColor="#FFFFFF"
        android:textSize="50dp"
        android:textStyle="bold"
        android:layout_alignParentTop="false"
        android:layout_toEndOf="@id/imageView2" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_marginTop="42dp"
        app:srcCompat="@drawable/home_icon"
        android:contentDescription="House" />

    <Button
        android:id="@+id/searchbtn"
        android:layout_width="296dp"
        android:layout_height="52dp"
        android:background="@drawable/design_box"
        android:gravity="center"
        android:hint="Search"
        android:onClick="onclicksearchbtn"
        android:textSize="32dp"
        android:layout_marginTop="28dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/Homepage" />

    <EditText
        android:id="@+id/editText"
        android:layout_width="216dp"
        android:layout_height="55dp"
        android:layout_marginTop="20dp"
        android:ems="8"
        android:gravity="center"
        android:hint="Location"
        android:textColor="@android:color/white"
        android:textColorHint="@android:color/white"
        android:textSize="24dp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/searchbtn" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/homegradient">

        <Button
            android:id="@+id/stationary"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/stationary"
            app:layout_constraintStart_toStartOf="@id/cover"
            app:layout_constraintTop_toTopOf="@id/cover" />

        <Button
            android:id="@+id/grocery"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/grocery"
            app:layout_constraintEnd_toEndOf="@id/cover"
            app:layout_constraintTop_toTopOf="@id/cover" />

        <Button
            android:id="@+id/convenience"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/convenience"

            app:layout_constraintBottom_toBottomOf="@id/cover"
            app:layout_constraintEnd_toEndOf="@id/cover" />

        <Button
            android:id="@+id/medical"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/medicine"
            app:layout_constraintBottom_toBottomOf="@id/cover"
            app:layout_constraintStart_toStartOf="@id/cover" />

        <TextView
            android:id="@+id/cover"
            android:layout_width="256dp"
            android:layout_height="256dp"

            android:background="@drawable/box"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</RelativeLayout>