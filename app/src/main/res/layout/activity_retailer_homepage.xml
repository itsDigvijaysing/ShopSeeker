<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RetailerHomepage"
    tools:ignore="HardcodedText,SpUsage">

    <EditText
        android:id="@+id/nocustomer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/homegradient"
        android:layout_marginTop="10dp"
        android:layout_toEndOf="@id/customer_show"
        android:text=" 3 " />

    <TextView
        android:id="@+id/homegradient"
        android:layout_width="match_parent"
        android:layout_height="196dp"
        android:background="@drawable/home_gradient"
        android:layout_alignParentTop="true" />

    <TextView
        android:id="@+id/customer_show"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text=" No. of Customer in Queue :-"
        android:textStyle="bold"
        android:textSize="22dp"
        android:layout_below="@id/homegradient"
        android:layout_marginStart="20dp" />

    <TextView
        android:id="@+id/Homepage"
        android:layout_width="321dp"
        android:layout_height="72dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="44dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:shadowColor="#99000000"
        android:shadowDx="3"
        android:shadowDy="3"
        android:shadowRadius="3"
        android:text="ShopSeeker"
        android:textColor="#FFFFFF"
        android:textSize="50dp"
        android:textStyle="bold"
        android:layout_alignParentTop="false"
        android:layout_toEndOf="@id/imageView2" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_marginTop="42dp"
        app:srcCompat="@drawable/home_icon"
        android:contentDescription="House" />

    <ListView
        android:id="@+id/list_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/customer_show"
        android:layout_marginTop="10dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp"
        android:padding="10dp" />

</RelativeLayout>